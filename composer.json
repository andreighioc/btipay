{
    "name": "btipay/laravel",
    "description": "Laravel package for Banca Transilvania iPay payment processing - supports 1-Phase and 2-Phase payments, refunds, reversals, and order status queries.",
    "keywords": [
        "banca-transilvania",
        "bt",
        "ipay",
        "payment",
        "gateway",
        "laravel",
        "romania",
        "3dsecure"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "BT iPay Developer",
            "email": "dev@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "BtIpay\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BtIpay\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BtIpay\\Laravel\\BtIpayServiceProvider"
            ],
            "aliases": {
                "BtIpay": "BtIpay\\Laravel\\Facades\\BtIpay"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
